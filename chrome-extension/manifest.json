{
  "manifest_version": 3,
  "name": "Vibe My Todo - 待办事项",
  "version": "1.0.0",
  "description": "功能完整的待办事项管理插件，支持离线使用，数据同步",
  "default_locale": "zh_CN",
  "icons": {
    "16": "icons/icon-16.png"
  },
  "permissions": [
    "storage",
    "notifications",
    "alarms",
    "background"
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-16.png"
    },
    "default_title": "Vibe My Todo"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "commands": {
    "add-todo": {
      "suggested_key": {
        "default": "Ctrl+Shift+T",
        "mac": "Command+Shift+T"
      },
      "description": "快速添加待办事项"
    }
  }
}
